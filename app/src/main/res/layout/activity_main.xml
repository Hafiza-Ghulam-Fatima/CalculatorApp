<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1A1A2E"
    android:padding="12dp">

    <!-- Display -->
    <TextView
        android:id="@+id/tvDisplay"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:text="0"
        android:textSize="44sp"
        android:textColor="#FFFFFF"
        android:gravity="end|bottom"
        android:padding="20dp"
        android:background="#0F3460"/>

    <!-- Row 1 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <Button android:id="@+id/btn7" android:text="7" style="@style/NumBtn"/>
        <Button android:id="@+id/btn8" android:text="8" style="@style/NumBtn"/>
        <Button android:id="@+id/btn9" android:text="9" style="@style/NumBtn"/>
        <Button android:id="@+id/btnDivide" android:text="/" style="@style/OpBtn"/>

    </LinearLayout>

    <!-- Row 2 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <Button android:id="@+id/btn4" android:text="4" style="@style/NumBtn"/>
        <Button android:id="@+id/btn5" android:text="5" style="@style/NumBtn"/>
        <Button android:id="@+id/btn6" android:text="6" style="@style/NumBtn"/>
        <Button android:id="@+id/btnMultiply" android:text="*" style="@style/OpBtn"/>

    </LinearLayout>

    <!-- Row 3 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <Button android:id="@+id/btn1" android:text="1" style="@style/NumBtn"/>
        <Button android:id="@+id/btn2" android:text="2" style="@style/NumBtn"/>
        <Button android:id="@+id/btn3" android:text="3" style="@style/NumBtn"/>
        <Button android:id="@+id/btnSubtract" android:text="-" style="@style/OpBtn"/>

    </LinearLayout>

    <!-- Row 4 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <Button android:id="@+id/btnDot" android:text="." style="@style/NumBtn"/>
        <Button android:id="@+id/btn0" android:text="0" style="@style/NumBtn"/>
        <Button android:id="@+id/btnClear" android:text="C" style="@style/FuncBtn"/>
        <Button android:id="@+id/btnAdd" android:text="+" style="@style/OpBtn"/>

    </LinearLayout>

    <!-- Equal Button -->
    <Button
        android:id="@+id/btnEquals"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="="
        android:textSize="26sp"
        android:textColor="#FFFFFF"
        android:backgroundTint="#1F6FEB"/>

</LinearLayout>